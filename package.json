{
  "name": "awesome-convert",
  "version": "1.0.0",
  "description": "万能文件格式转换工具 - 纯本地运行，支持压缩包、视频、音频、图片、文档等格式互转",
  "main": "dist-electron/main/index.js",
  "author": {
    "name": "JIAJIA-nya",
    "email": "313841130@qq.com"
  },
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.node.json && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.node.json && electron .",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "build:win": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "auto-launch": "^5.0.6",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.1",
    "electron-store": "^8.2.0",
    "extract-zip": "^2.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.8.0",
    "marked": "^15.0.4",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.jiajia.awesomeconvert",
    "productName": "Awesome-Convert",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "build/**/*",
      "node_modules/**/*"
    ],
    "asar": false,
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
